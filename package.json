{
  "name": "@whisperr/react-native",
  "version": "0.2.1",
  "description": "Whisperr React Native SDK — reliable, Expo-friendly churn-signal event tracking with zero native code.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-native": ">=0.65"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "react-native": "^0.75.0",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "fast-xml-parser": "^5.7.0"
  },
  "keywords": [
    "whisperr",
    "react-native",
    "expo",
    "analytics",
    "churn",
    "events"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhisperrAI/whisperr-react-native.git"
  },
  "homepage": "https://github.com/WhisperrAI/whisperr-react-native#readme"
}
